---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { type Lang, useTranslations } from '../../../i18n/ui';

const lang: Lang = 'hu';
const t = useTranslations(lang);

const title = t('notesAndExperimentsName');
const status = t('notesAndExperimentsStatus');
const description = t('notesAndExperimentsDescription');
const cta = t('notesAndExperimentsCta');
const ctaUrl = '/hu/jegyzetek/';
const reason = '';
const qualifier = '';

const projectsBase = '/hu/projektek/';
const statusClass = 'project-status--ongoing';
---

<BaseLayout lang={lang} title={title + ' — ' + t('siteTitle')} description={description}>
  <article class="note-detail">
    <div class="container">
      <h1>{title}</h1>
      <p class:list={['project-status', statusClass]}>
        {t('projectStatus')}: {status}
      </p>

      <div class="prose" style="margin-top: var(--space-5);">
        <p style="font-size: var(--step-1);">{description}</p>

        {reason && (
          <div style="margin-top: var(--space-5);">
            <h2>{t('projectWhy')}</h2>
            <p>{reason}</p>
          </div>
        )}

        {qualifier && (
          <div class="project-qualifier" style="margin-top: var(--space-4);">
            {qualifier}
          </div>
        )}
      </div>

      <div style="margin-top: var(--space-5);">
        {ctaUrl ? (
          <a href={ctaUrl} class="btn btn-primary" target={ctaUrl.startsWith('http') ? '_blank' : undefined} rel={ctaUrl.startsWith('http') ? 'noopener' : undefined}>
            {cta} →
          </a>
        ) : (
          <span class="btn btn-primary" style="opacity: 0.5; cursor: default;">
            {cta}
          </span>
        )}
      </div>

      <div style="margin-top: var(--space-6);">
        <a href={projectsBase} class="btn btn-secondary">{t('backToProjects')}</a>
      </div>
    </div>
  </article>
</BaseLayout>
