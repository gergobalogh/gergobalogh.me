---
import { type Lang, useTranslations } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const notesPath = lang === 'ro' ? '/ro/notite/' : lang === 'hu' ? '/hu/jegyzetek/' : '/notes/';
---

<section class="section hero-section fade-in">
  <div class="container hero-grid">
    <div class="hero-text">
      <h1 class="hero-headline">{t('heroHeadline')}</h1>
      <p class="hero-subhead">{t('heroSubhead')}</p>
      <div class="btn-group">
        <a href="#projects" class="btn btn-primary" data-umami-event="hero-cta-primary">{t('heroCta')}</a>
        <a href={notesPath} class="btn btn-secondary" data-umami-event="hero-cta-secondary">{t('heroCtaSecondary')}</a>
      </div>
    </div>
    <div class="hero-portrait">
      <div class="portrait">
        <img src="/portrait-optimized.jpg" alt="Gergő Balogh" width="840" height="840" loading="eager" />
      </div>
    </div>
  </div>
</section>

<style>
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-6);
    align-items: center;
  }

  .hero-headline {
    margin-bottom: var(--space-3);
  }

  .hero-subhead {
    font-size: var(--step-1);
    color: var(--muted);
    margin-bottom: var(--space-4);
    max-width: var(--measure);
  }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }

    .hero-portrait {
      order: -1;
    }

    .portrait {
      width: 200px;
      height: 200px;
    }
  }
</style>
